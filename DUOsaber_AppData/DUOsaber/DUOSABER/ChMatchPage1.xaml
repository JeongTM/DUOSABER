<Page x:Name="Page" x:Class="DUOsaber.ChMatchPage1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DUOsaber"
      mc:Ignorable="d" 
      Title="ChMatchPage1" Width="536" Height="556">
    <Page.Resources>
        <ControlTemplate x:Key="NoMouseOverButtonTemplate" TargetType="Button">
            <Border 
                Background="{TemplateBinding Background}"  
                BorderBrush="{TemplateBinding BorderBrush}"  
                BorderThickness="{TemplateBinding BorderThickness}" Padding="5,0,5,0">
                <ContentPresenter 
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{x:Static SystemColors.ControlLightBrush}" />
                    <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}" />

                </Trigger>

            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Page.Resources>
    <Grid>
        <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="MatchingStartButton" Content="다음" HorizontalAlignment="Center" Height="32" VerticalAlignment="Bottom" Width="90" Background="#02000000" Foreground="White" BorderBrush="White" Margin="0,0,0,38" Click="MatchingStartButton_Click">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
        <Label x:Name="pwd" Content="설정 &gt; 신규 기기 등록" HorizontalAlignment="Left" Margin="47,32,0,0" VerticalAlignment="Top" Foreground="White" FontSize="24" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="MatchingEndButton" Content="다음" HorizontalAlignment="Center" Height="32" VerticalAlignment="Bottom" Width="90" Background="#02000000" Foreground="White" BorderBrush="White" Click="MatchingEndButton_Click" Visibility="Hidden" Margin="0,0,0,38">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
        <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="MatchingExitButton" Content="홈 화면으로 이동" HorizontalAlignment="Center" Height="32" VerticalAlignment="Bottom" Background="#02000000" Foreground="White" BorderBrush="White" Click="MatchingExitButton_Click" Visibility="Hidden" Padding="10,1,10,1" Width="120" Margin="0,0,0,38">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
        <Grid x:Name="MatchingLabel1" UseLayoutRounding="False" ClipToBounds="True">
            <Label x:Name="CMtext1"  Content="기기 본체 준비" HorizontalAlignment="Left" Margin="47,70,0,0" VerticalAlignment="Top" Foreground="White" FontSize="20" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Label x:Name="CMtext1_1"  Content="그림에 표시된 버튼을 2초간 눌러주세요." HorizontalAlignment="Left" Margin="47,107,0,0" VerticalAlignment="Top" Foreground="White" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Label x:Name="CMtext1_2"  Content="등록할 준비가 되면 프리젠터의 LED가 반짝입니다." HorizontalAlignment="Left" Margin="47,130,0,0" VerticalAlignment="Top" Foreground="White" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Image Margin="142,197,0,0" Source="/170Y1-1.png" HorizontalAlignment="Left" Width="80" Height="364" VerticalAlignment="Top"/>
            <Image Source="/300y1-1.png" Margin="52,169,0,-151" HorizontalAlignment="Left" Width="90" Height="390" VerticalAlignment="Top"/>
            <Image Source="/180Y1-1.png" Margin="339,197,0,0" HorizontalAlignment="Left" Width="166" Height="502" VerticalAlignment="Top"/>

        </Grid>
        <Grid x:Name="MatchingLabel2" ClipToBounds="True" Visibility="Hidden">
            <Label x:Name="CMtext2"  Content="기기 등록 진행" HorizontalAlignment="Left" Margin="47,70,0,0" VerticalAlignment="Top" Foreground="White" FontSize="20" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Label x:Name="CMtext2_1"  Content="등록이 완료되면 프리젠터의 LED가 깜빡임을 멈춥니다.." HorizontalAlignment="Left" Margin="47,107,0,0" VerticalAlignment="Top" Foreground="White" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Label x:Name="CMtext2_2"  Content="깜빡임이 멈춘 것을 확인하면 '다음'을 클릭해주세요" HorizontalAlignment="Left" Margin="47,130,0,0" VerticalAlignment="Top" Foreground="White" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Image Source="/170Y1-2.png" Margin="142,197,289,-195" Width="80" Height="364" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <Image Source="/180Y1-2.png" Margin="339,197,0,0" HorizontalAlignment="Left" Width="166" Height="502" VerticalAlignment="Top"/>
            <Image Source="/300y1-2.png" Margin="52,169,365,-147" Width="90" HorizontalAlignment="Left" VerticalAlignment="Top" Height="392"/>
        </Grid>
        <Grid x:Name="MatchingLabel3" Visibility="Hidden">
            <Label  Content="기기 등록 완료" HorizontalAlignment="Left" Margin="47,70,0,0" VerticalAlignment="Top" Foreground="White" FontSize="20" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Label  Content="프리젠터를 조작하여 연결을 확인하세요." HorizontalAlignment="Left" Margin="47,107,0,0" VerticalAlignment="Top" Foreground="White" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        </Grid>
        <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="BackToSetting" HorizontalAlignment="Left" VerticalAlignment="Top" Height="24" Width="24" Margin="16,42,0,0" BorderBrush="{x:Null}" Click="BackToSetting_Click" Cursor="Hand" Background="{x:Null}">
            <Image Source="/LaftArrow1.png" RenderTransformOrigin="0.5,0.4">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="3.5" ScaleY="3.5"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Button>

    </Grid>
</Page>
