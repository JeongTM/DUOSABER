<Window x:Class="DUOsaber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DUOsaber"
        xmlns:localization="clr-namespace:DUOsaber.Localization"
        mc:Ignorable="d"
        Title="DUOSABER_v1.2" Closing="Window_Closing" ResizeMode="CanMinimize" WindowStyle="None" AllowsTransparency="True" Background="{x:Null}" MouseMove="TopBar_MouseMove" MouseLeave="Window_MouseLeave" VerticalAlignment="Top" Height="596" Width="676" StateChanged="Window_StateChanged">
    <Window.Resources>
        <ControlTemplate x:Key="NoMouseOverButtonTemplate" TargetType="Button">
            <Border 
                Background="{TemplateBinding Background}"  
                BorderBrush="{TemplateBinding BorderBrush}"  
                BorderThickness="{TemplateBinding BorderThickness}" Padding="5,0,5,0">
                <ContentPresenter 
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{x:Static SystemColors.ControlLightBrush}" />
                    <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}" />

                </Trigger>

            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>
    <Grid x:Name="MainGrid" Width="676">
        <Border Margin="0,41,0,0" CornerRadius="0,0,10,10">
            <Border.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#FF1A1B26"/>
                    <GradientStop Color="#FF20212F" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        <Border x:Name="PTmodePanel" Height="69" Width="496" Margin="0,0,20,17" VerticalAlignment="Bottom" CornerRadius="4,4,4,4" Background="#4C000000" HorizontalAlignment="Right">
            <Grid>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="PTmodeSet" Content="프레젠테이션 모드" HorizontalAlignment="Left" Margin="91,0,0,0" VerticalAlignment="Center" Click="PTmodeSet_Click" Padding="0,0,0,0" Panel.ZIndex="3" BorderBrush="White" Foreground="White" Background="#00000000" FontSize="14" Height="37" BorderThickness="2,2,2,2" Cursor="Hand" Width="140">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="MeetingModeSet" Content="회의 모드" HorizontalAlignment="Right" VerticalAlignment="Center" Click="MeetingModeSet_Click" Padding="0,0,0,0" Panel.ZIndex="3" BorderBrush="White" Foreground="White" Background="#00FF6B00" FontSize="14" Width="140" Height="35" Grid.IsSharedSizeScope="True" Margin="0,0,91,0" BorderThickness="2,2,2,2" Cursor="Hand" >
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="TopBar" CornerRadius="10,10,0,0" Height="41" Background="#FF2E2D2D" VerticalAlignment="Top" MouseDown="TopBar_MouseDown" MouseUp="TopBar_MouseUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="CloseButton" HorizontalAlignment="Left" Width="66" BorderBrush="#02000000" Foreground="{x:Null}" Click="CloseButton_Click" Cursor="Hand" MouseEnter="CloseButton_MouseEnter" MouseLeave="CloseButton_MouseLeave" BorderThickness="0,0,0,0" Background="{x:Null}" Grid.Column="5">
                    <Image Source="/close.png" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="0.4" ScaleY="0.4"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,10,0,0"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="MinimizedButton" HorizontalAlignment="Left" Width="66" BorderBrush="{x:Null}" Foreground="{x:Null}" Click="MinimizedButton_Click" Cursor="Hand" Background="#02000000" BorderThickness="0,0,0,0" MouseEnter="MinimizedButton_MouseEnter" MouseLeave="MinimizedButton_MouseLeave" Grid.Column="4">
                    <Image Source="/min.png" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="0.3" ScaleY="0.4"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Button>
                <Image Height="35" Width="35" HorizontalAlignment="Left" Margin="15,0,0,0" Source="/DUOicon.png"/>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="SettingButton" Content="설정" HorizontalAlignment="Left" Margin="10,0,0,8" VerticalAlignment="Bottom" Click="SettingButton_Click" BorderBrush="{x:Null}" ScrollViewer.VerticalScrollBarVisibility="Hidden" Background="#007B7B7B" Foreground="#E5FFFFFF" FontSize="18" Cursor="Hand" Grid.Column="2">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="EditButton" Content="홈" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" BorderBrush="{x:Null}" ScrollViewer.VerticalScrollBarVisibility="Hidden" Background="#FF7B7B7B" Foreground="#E5FFFFFF" FontSize="18" Cursor="Hand" Click="EditButton_Click" MinWidth="47" Grid.Column="1">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <StaticResource ResourceKey="NoMouseOverButtonTemplate"/>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        <Border BorderBrush="Black" CornerRadius="0,0,10,10" Width="140" Margin="0,41,0,0" HorizontalAlignment="Left">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF12131B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Label x:Name="arrow0" Content="▷" HorizontalAlignment="Right" Height="18" Margin="0,0,9,0" VerticalAlignment="Center" Width="19" Foreground="White" Padding="0,0,0,0" HorizontalContentAlignment="Center" Grid.Row="1"/>
                <Label x:Name="arrow1" Content="▷" HorizontalAlignment="Right" Height="18" Margin="0,20,9,0" VerticalAlignment="Center" Width="19" Foreground="White" Padding="0,0,0,0" HorizontalContentAlignment="Center" Grid.Row="2"/>
                <Label x:Name="arrow2" Content="▷" HorizontalAlignment="Right" Height="18" Margin="0,20,9,0" VerticalAlignment="Center" Width="19" Foreground="White" Padding="0,0,0,0" HorizontalContentAlignment="Center" Grid.Row="3"/>
                <Label x:Name="arrow3" Content="▷" HorizontalAlignment="Right" Height="18" Margin="0,20,9,0" VerticalAlignment="Center" Width="19" Foreground="White" Padding="0,0,0,0" HorizontalContentAlignment="Center" Grid.Row="4"/>

                <Button x:Name="PointPageButton" Template="{StaticResource NoMouseOverButtonTemplate}" Content="    컬러"  HorizontalAlignment="Center" Height="27" VerticalAlignment="Top" Width="140" Click="PointPageButton_Click" BorderBrush="#66707070" Background="#02000000" Foreground="White" HorizontalContentAlignment="Left" FontSize="14" BorderThickness="0,0,0,0" Cursor="Hand" MouseEnter="ImagePageButton_MouseEnter" MouseLeave="ImagePageButton_MouseLeave" Tag="1" Grid.Row="2" Margin="0,20,0,0"/>
                <Button x:Name="ImagePageButton" Template="{StaticResource NoMouseOverButtonTemplate}" Content="    이미지" HorizontalAlignment="Center" Height="27" VerticalAlignment="Top" Width="140" Click="ImagePageButton_Click" BorderBrush="#66707070" Background="#02000000" Foreground="White" HorizontalContentAlignment="Left" FontSize="14" BorderThickness="0,0,0,0" Cursor="Hand" MouseLeave="ImagePageButton_MouseLeave" MouseEnter="ImagePageButton_MouseEnter" Tag="0" Grid.Row="1"/>
                <Button x:Name="MagnifierPageButton" Template="{StaticResource NoMouseOverButtonTemplate}" Content="    확대경" HorizontalAlignment="Center" Height="27" VerticalAlignment="Top" Width="140" BorderBrush="#66707070" Click="MagnifierPageButton_Click" Background="#02000000" Foreground="White" HorizontalContentAlignment="Left" FontSize="14" BorderThickness="0,0,0,0" Cursor="Hand" MouseLeave="ImagePageButton_MouseLeave" MouseEnter="ImagePageButton_MouseEnter" Tag="2" Grid.Row="3" Margin="0,20,0,0"/>
                <Button x:Name="SpotLightPageButton" Template="{StaticResource NoMouseOverButtonTemplate}" Content="    하이라이트" HorizontalAlignment="Center" Height="27" VerticalAlignment="Top" Width="140" BorderBrush="#66707070" Click="SpotLightPageButton_Click" Background="#02000000" Foreground="White" HorizontalContentAlignment="Left" FontSize="14" BorderThickness="0,0,0,0" Cursor="Hand" MouseEnter="ImagePageButton_MouseEnter" MouseLeave="ImagePageButton_MouseLeave" Tag="3" Grid.Row="4" Margin="0,20,0,0"/>
            </Grid>
        </Border>
        <Image Height="44" Margin="13,89,0,0" Source="/DUOsaberlogo-removebg-preview.png" VerticalAlignment="Top" HorizontalAlignment="Left" Width="115"/>

        <Frame x:Name="PointerFrame" Content="" HorizontalAlignment="Right" VerticalAlignment="Top" NavigationUIVisibility="Hidden" Width="536" Margin="0,41,0,0" Navigating="PointerFrame_Navigating" SizeChanged="PointerFrame_SizeChanged"/>
        <Grid Margin="140,41,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="Flag_A" Content="발표자" HorizontalAlignment="Center" Margin="0,90,0,0" VerticalAlignment="Top" Width="120" FontFamily="MS Reference Sans Serif" VerticalContentAlignment="Center" FontSize="18" HorizontalContentAlignment="Center" Foreground="White" Grid.Column="1"/>
            <Label x:Name="Flag_B" Content="청중1" HorizontalAlignment="Center" Margin="0,90,0,0" Width="120" FontFamily="MS Reference Sans Serif" VerticalContentAlignment="Center" FontSize="18" HorizontalContentAlignment="Center" Foreground="White" VerticalAlignment="Top" Grid.Column="2"/>
            <Label x:Name="Flag_C" Content="청중2" HorizontalAlignment="Center" Margin="0,90,0,0" VerticalAlignment="Top" Width="120" FontFamily="MS Reference Sans Serif" FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Foreground="White" Grid.Column="3"/>
        </Grid>
        <Border x:Name="SettingPanel" BorderBrush="Black" CornerRadius="0,0,10,10" Width="140" Margin="0,41,0,0" HorizontalAlignment="Left" ScrollViewer.VerticalScrollBarVisibility="Hidden" Visibility="Hidden">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FF1F1F1F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="SettingPanelButton" Content="▶ 환경설정" Foreground="#FFFF6B00" FontSize="14" VerticalAlignment="Top" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Margin="14,70,2,0" Background="{x:Null}" BorderBrush="{x:Null}" Click="SettingPanelButton_Click"/>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="SelectMainDevButton" Content="▶ 발표자 변경" Margin="14,101,2,0" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White" FontSize="14" VerticalAlignment="Top" HorizontalContentAlignment="Left" Click="SelectMainDevButton_Click" Cursor="Hand"/>
                <Button Template="{StaticResource NoMouseOverButtonTemplate}" x:Name="NewDeviceButton" Content="▶ 신규 기기 등록" Width="124" Margin="14,132,0,0" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Top" HorizontalContentAlignment="Left" Click="NewDeviceButton_Click" Cursor="Hand" Padding="0,1,1,1"/>
                <Label x:Name="settingMain" Content="설정" Foreground="#FFFF6B00" VerticalAlignment="Top" FontSize="16" Margin="0,39,0,0" HorizontalAlignment="Right" Width="126"/>
            </Grid>
        </Border>
        <Label x:Name="verLabel" Content="DUOSABER v1.2" Foreground="#CCFFFFFF" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,5" FontSize="16" Visibility="Hidden"/>

        <Image x:Name="choisLogo" Source="/chois_logo.png" Height="20" Width="100" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="20,0,0,20" Grid.Row="6"/>
        <Border x:Name="NotConnect" Background="#FF171717" CornerRadius="0,0,10,10" Margin="0,41,0,0" Visibility="Hidden">
            <Grid>
                <Label x:Name="plzConnection" Content="수신기를 연결해주세요" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24" FontWeight="SemiBold" Margin="0,391,0,0"/>
                <Label x:Name="connectionFaild" Content="연결 실패" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24" FontWeight="SemiBold" Margin="0,113,0,0"/>
                <Image Source="/btn_icon_exclamation-removebg-preview.png" VerticalAlignment="Center" Width="233" Height="233" HorizontalAlignment="Center"/>
                <Label x:Name="verLabel1" Content="DUOSAVER v1.2" Foreground="#CCFFFFFF" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,86" FontSize="16"/>
            </Grid>
        </Border>

    </Grid>
</Window>
