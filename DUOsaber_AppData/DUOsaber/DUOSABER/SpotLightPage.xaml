<Page x:Class="DUOsaber.SpotLightPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DUOsaber"
      mc:Ignorable="d" d:DesignWidth="536"
      Title="SpotLightPage" Width="536">
    <Page.Resources>
        <ControlTemplate x:Key="NoMouseOverButtonTemplate" TargetType="Button">
            <Border 
                Background="{TemplateBinding Background}"  
                BorderBrush="{TemplateBinding BorderBrush}"  
                BorderThickness="{TemplateBinding BorderThickness}" Padding="5,0,5,0">
                <ContentPresenter 
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{x:Static SystemColors.ControlLightBrush}" />
                    <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}" />

                </Trigger>

            </ControlTemplate.Triggers>
        </ControlTemplate>

        <SolidColorBrush x:Key="CustomSliderBackgroundSolidColorBrushKey" Color="#55ffffff" />
        <SolidColorBrush x:Key="CustomSliderForegroundSolidColorBrushKey" Color="White" />
        <SolidColorBrush x:Key="CustomSliderHighlightSolidColorBrushKey"  Color="#FFFF7E21" />
        <ControlTemplate x:Key="CustomSliderThumbControlTemplateKey" TargetType="{x:Type Thumb}">
            <Grid
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                UseLayoutRounding="True">
                <Rectangle x:Name="gripRectangle"
                    Width="8"
                    Height="{Binding Path=Height, RelativeSource={RelativeSource TemplatedParent}}"
                    RadiusX="3"
                    RadiusY="3"
                    StrokeThickness="0"
                    Stretch="Fill"
                    Fill="#FFFF6B00"
                    UseLayoutRounding="True" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsDragging" Value="true">
                    <Setter
                        TargetName="gripRectangle"
                        Property="Fill"
                        Value="{StaticResource CustomSliderHighlightSolidColorBrushKey}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="false">
                    <Setter
                        TargetName="gripRectangle"
                        Property="Fill"
                        Value="{StaticResource CustomSliderBackgroundSolidColorBrushKey}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="true">
                    <Setter
                        TargetName="gripRectangle"
                        Property="Fill"
                        Value="{StaticResource CustomSliderForegroundSolidColorBrushKey}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <ControlTemplate x:Key="CustomSliderControlTemplateKey" TargetType="{x:Type Slider}">
            <Border x:Name="border"
                Background="Transparent"
                SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{TemplateBinding MinHeight}" />
                    </Grid.RowDefinitions>
                    <DockPanel LastChildFill="True">
                        <Border x:Name="PART_SelectionRange"
                            Height="3"
                            ClipToBounds="True"
                            Visibility="Visible">
                            <Rectangle
                                Margin="4 0 -4 0"
                                RadiusX="1"
                                RadiusY="1"
                                Fill="{StaticResource CustomSliderHighlightSolidColorBrushKey}" />
                        </Border>
                        <Border
                            Height="3"
                            ClipToBounds="True"
                            Visibility="Visible">
                            <Rectangle x:Name="PART_NegativeSelection"
                                Margin="8 0 4 0"
                                RadiusX="1"
                                RadiusY="1"
                                Fill="{DynamicResource CustomSliderForegroundSolidColorBrushKey}" />
                        </Border>
                    </DockPanel>
                    <Track x:Name="PART_Track">
                        <Track.Thumb>
                            <Thumb x:Name="Thumb"
                                Template="{StaticResource CustomSliderThumbControlTemplateKey}"
                                OverridesDefaultStyle="True"
                                VerticalAlignment="Center"
                                Width="8"
                                Height="{TemplateBinding MinHeight}"
                                Focusable="False" />
                        </Track.Thumb>
                    </Track>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding ElementName=Thumb, Path=IsDragging}" Value="True">
                    <Setter
                        TargetName="PART_NegativeSelection"
                        Property="Fill"
                        Value="{StaticResource CustomSliderForegroundSolidColorBrushKey}" />
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="CustomSliderStyleKey" TargetType="{x:Type Slider}">
            <Setter Property="Template"                     Value="{StaticResource CustomSliderControlTemplateKey}" />
            <Setter Property="VerticalAlignment"            Value="Center"      />
            <Setter Property="MinHeight"                    Value="26"          />
            <Setter Property="MaxHeight"                    Value="26"          />
            <Setter Property="Height"                       Value="26"          />
            <Setter Property="BorderBrush"                  Value="Transparent" />
            <Setter Property="Background"                   Value="Transparent" />
            <Setter Property="IsMoveToPointEnabled"         Value="True"        />
            <Setter Property="AutoToolTipPlacement"         Value="None"        />
            <Setter Property="IsSnapToTickEnabled"          Value="True"        />
            <Setter Property="TickFrequency"                Value="0.01"        />
            <Setter Property="SmallChange"                  Value="0.01"        />
            <Setter Property="LargeChange"                  Value="0.01"        />
            <Setter Property="Minimum"                      Value="0"           />
            <Setter Property="SelectionStart"               Value="{Binding Path=Minimum, RelativeSource={RelativeSource Self}}" />
            <Setter Property="SelectionEnd"                 Value="{Binding Path=Value, RelativeSource={RelativeSource Self}}"   />
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"       />
        </Style>
    </Page.Resources>
    <Grid>
        <Border BorderBrush="Black" BorderThickness="1" Width="496" Height="238" Margin="20,66,20,0" VerticalAlignment="Top" CornerRadius="4,4,4,4" Background="#FF1A1B26">
            <Grid Width="496" Height="238">
                <Image Source="/xpointerLogo_chois.png" VerticalAlignment="Top" Margin="0,60,0,0"/>
                <Rectangle x:Name="SpotlighSampleView" Stroke="Black" Width="494" Height="238">
                    <Rectangle.Fill>
                        <RadialGradientBrush x:Name="spotSampleBrush" RadiusX="0.2" Center="0.1,0.5" GradientOrigin="0.2,0.5" RadiusY="0.4">
                            <GradientStop Offset="0.5"/>
                            <GradientStop Color="Black" Offset="0.5"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </Border>
        <Border BorderThickness="1" Width="496" Height="143" Margin="20,314,20,0" VerticalAlignment="Top" CornerRadius="4,4,4,4" Background="#4C000000">
            <Grid>
                <Label Content="-" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" Margin="108,23,0,0" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5" MouseLeftButtonDown="Label_MouseLeftButtonDown_1">
                    <Label.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="2"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Label.RenderTransform>
                </Label>
                <Label Content="+" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" Margin="429,23,0,0" HorizontalAlignment="Left" MouseLeftButtonDown="Label_MouseLeftButtonDown"/>

                <Label Content="0" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" Margin="106,72,366,0" MouseLeftButtonDown="Label_MouseLeftButtonDown_3"/>
                <Label Content="100" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" Margin="419,72,30,0" MouseLeftButtonDown="Label_MouseLeftButtonDown_2"/>

                <Label x:Name="OpacityLabel" Content="투명도&#xA;" HorizontalAlignment="Left" Margin="23,79,0,0" Width="72" FontFamily="MS Reference Sans Serif" FontSize="14" Foreground="White" Height="27" VerticalAlignment="Top"/>
                <Slider Style="{DynamicResource CustomSliderStyleKey}" x:Name="SpotlightSizeSlider" HorizontalAlignment="Right" Height="30" Margin="0,31,77,0" VerticalAlignment="Top" Width="275" Maximum="40" SmallChange="1" Value="20" Minimum="10" ValueChanged="SpotlightSizeSlider_ValueChanged" Cursor="Hand" AutoToolTipPlacement="TopLeft"/>
                <Label x:Name="SizeLabel" Content="크기" HorizontalAlignment="Left" Margin="23,34,0,0" Width="45" FontFamily="MS Reference Sans Serif" FontSize="14" Foreground="White" Height="27" RenderTransformOrigin="0.649,0.324" VerticalAlignment="Top"/>
                <Slider Style="{DynamicResource CustomSliderStyleKey}" x:Name="BaseOpacitySlider" HorizontalAlignment="Right" Height="30" Margin="0,79,76,23" VerticalAlignment="Top" Width="275" Maximum="100" SmallChange="1" Minimum="10" ValueChanged="BaseOpacitySlider_ValueChanged" Value="50" Cursor="Hand" AutoToolTipPlacement="TopLeft"/>
            </Grid>
        </Border>
        <Label x:Name="SpotlightLabel" Content="하이라이트" FontSize="24" Foreground="White" FontWeight="Light" Height="50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,15,0,0"/>

    </Grid>
</Page>
